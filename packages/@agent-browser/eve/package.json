{
  "name": "@agent-browser/eve",
  "version": "0.31.2",
  "description": "eve extension that gives agents a full browser automation tool set backed by agent-browser",
  "type": "module",
  "sideEffects": false,
  "eve": {
    "extension": "./extension"
  },
  "files": [
    "extension",
    "dist",
    "README.md"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.mjs"
    },
    "./tools": {
      "types": "./dist/tools/index.d.ts",
      "default": "./dist/tools/index.mjs"
    }
  },
  "scripts": {
    "build": "eve extension build",
    "prepare": "eve extension build",
    "test": "pnpm run build && node --test test/*.test.mjs",
    "typecheck": "tsc"
  },
  "keywords": [
    "agent-browser",
    "eve",
    "eve-extension",
    "browser-automation",
    "sandbox"
  ],
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/vercel-labs/agent-browser",
    "directory": "packages/@agent-browser/eve"
  },
  "bugs": {
    "url": "https://github.com/vercel-labs/agent-browser/issues"
  },
  "homepage": "https://agent-browser.dev",
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@agent-browser/sandbox": "^0.31.2",
    "zod": "4.4.3"
  },
  "peerDependencies": {
    "eve": "^0.22.5"
  },
  "devDependencies": {
    "@types/node": "24.x",
    "eve": "^0.22.5",
    "typescript": "5.9.3"
  },
  "engines": {
    "node": ">=24.0.0"
  }
}
