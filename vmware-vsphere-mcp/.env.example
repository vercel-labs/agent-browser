# VMware vCenter Connection Settings
VCENTER_HOST=vcenter.your-domain.local
VCENTER_USER=administrator@vsphere.local
VCENTER_PASSWORD=your_password_here

# Set to True to skip SSL certificate verification (for self-signed certs)
INSECURE=True

# MCP Server Settings (usually no need to change)
SERVER_HOST=0.0.0.0
SERVER_PORT=8000
